# 33509
Куб: открыть~
0 c 1
хлестнуть~
if %arg% != куб
    wsend %actor% Хлестнуть что?
	halt
end

if %actor.eqvn(19)% == 33507
   wsend %actor% Вы хорошенько размашнулись и хлестнули куб. Еще бы чуть чуть и проделали бы в нем быру насквозь.
   wechoaround %actor% %actor.name% хорошенько размашнулись и хлестнул%actor.k% куб, в котором образовалался проход.
   
   if %self.vnum% = 33548
     wat 33504 wecho Неожданно с запада появился проход.
     wdoor 33548 восток room 33547
     wdoor 33547 запад room 33548
   end
   if %self.vnum% = 33546
     wat 33504 wecho Неожданно с запада появился проход.
     wdoor 33546 запад room 33547
     wdoor 33547 восток room 33546
   end
else
    wsend %actor%  Хлестнуть чем?
end
