# 33504
Поле травит~
2 g 30
~
eval number %random.2%
switch %number%
    
    case 2
        wait 1
        wecho Вы ощутили, как что-то липкое опутало Вас!
        wechoaround %actor% %actor.name_ro% обвило что-то липкое!
        wat 33500 wforce техмоб1 обкаст_игрока 2 %actor.room% %actor.name% 
        break

    case 1
        wait 1
        wecho Вы почувствовали, как какие-то водоросли прикоснулись к вашей коже.
        wechoaround %actor% %actor.name% случайно прикоснулся к бурым водорослям!
        wat 33500 wforce техмоб1 обкаст_игрока 1 %actor.room% %actor.name%
        break
        
done
~
# 33505
Техмоб: обкаст~
0 c 
обкаст_игрока~
*%arg.car% - возвращает первое слово в строке
*%arg.cdr% - возвращает строку без первого слова (и следующих за ним пробелов)

eval type %arg.car%
eval temp %arg.cdr%
eval room %temp.car%
eval user %temp.cdr%

switch %type%

    case 3
        *ЩИТ_МОРОЗА
        mgoto %room%
		mapply %user% 177
		mgoto 33500
        break
        
    case 2
        *холд
        mgoto %room%
		mapply %user% 58
		mgoto 33500
        break

    case 1
        *яд
        mgoto %room%
		mapply %user% 33
		mgoto 33500
        break
        
done 
~
